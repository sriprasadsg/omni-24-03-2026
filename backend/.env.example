# ============================================================
# Enterprise Omni-Agent Platform — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ── MongoDB ─────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
DATABASE_NAME=omni_agent_platform

# ── JWT Authentication ───────────────────────────────────────
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── LLM / AI Provider ───────────────────────────────────────
# Primary: Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here
# Fallback: OpenAI
OPENAI_API_KEY=your_openai_api_key_here
# Which provider to use: gemini | openai | ollama
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash
# Local Ollama URL (if using ollama)
OLLAMA_URL=http://localhost:11434

# ── Email / SMTP ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM_EMAIL=noreply@your-domain.com
SMTP_FROM_NAME=Omni-Agent Platform
SMTP_USE_TLS=true

# ── Stripe Payment Gateway ───────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ── Razorpay Payment Gateway ─────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ── Google OAuth / SSO ───────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
SSO_REDIRECT_URI=http://localhost:5000/api/sso/google/callback

# ── SAML / Enterprise SSO ────────────────────────────────────
SAML_IDP_METADATA_URL=https://your-idp.com/metadata.xml
SAML_SP_ENTITY_ID=https://your-domain.com/api/sso/saml/metadata

# ── MFA Settings ─────────────────────────────────────────────
MFA_APP_NAME=Omni-Agent Platform
MFA_ISSUER=omni-agent

# ── Redis Cache ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
CACHE_TTL=300

# ── AWS / Cloud Integrations ─────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-east-1

# ── Azure Integrations ───────────────────────────────────────
AZURE_CLIENT_ID=your_azure_client_id
AZURE_CLIENT_SECRET=your_azure_client_secret
AZURE_TENANT_ID=your_azure_tenant_id
AZURE_SUBSCRIPTION_ID=your_subscription_id

# ── GCP Integrations ─────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GCP_PROJECT_ID=your_gcp_project_id

# ── Voice Bot (Google Speech + TTS) ──────────────────────────
GOOGLE_SPEECH_CREDENTIALS=/path/to/speech-service-account.json

# ── SAST / Security Scanning ─────────────────────────────────
SEMGREP_APP_TOKEN=your_semgrep_token
ZAP_API_KEY=your_owasp_zap_api_key
ZAP_BASE_URL=http://localhost:8080

# ── Ticketing Integrations ───────────────────────────────────
JIRA_URL=https://your-org.atlassian.net
JIRA_EMAIL=your_email@company.com
JIRA_API_TOKEN=your_jira_api_token
SERVICENOW_URL=https://your-instance.service-now.com
SERVICENOW_USER=admin
SERVICENOW_PASS=your_password
PAGERDUTY_API_KEY=your_pagerduty_key

# ── Platform Settings ─────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000
ENVIRONMENT=development
DEBUG=false
PORT=5000
