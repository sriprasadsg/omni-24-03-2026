@app.get("/api/audit-logs")
async def get_simple_audit_logs():
    """Non-authenticated audit logs endpoint for initial data load"""
    db = get_database()
    tenant_id = get_tenant_id()
    query = {"tenantId": tenant_id} if tenant_id else {}
    logs = await db.audit_logs.find(query, {"_id": 0}).sort("timestamp", -1).limit(100).to_list(length=100)
    return logs

