@app.get("/api/metrics")
async def get_metrics():
    db = get_database()
    tenant_id = get_tenant_id()
    
    # Get counts for dashboard
    agents_count = await db.agents.count_documents({"tenantId": tenant_id} if tenant_id else {})
    assets_count = await db.assets.count_documents({"tenantId": tenant_id} if tenant_id else {})
    vulns_count = await db.vulnerabilities.count_documents({"tenantId": tenant_id} if tenant_id else {})
    
    # Return as array of metrics for Dashboard.map()
    return [
        {"name": "Total Agents", "value": agents_count, "icon": "server"},
        {"name": "Online Agents", "value": agents_count, "icon": "check-circle"},
        {"name": "Total Assets", "value": assets_count, "icon": "database"},
        {"name": "Critical Vulnerabilities", "value": vulns_count, "icon": "alert-triangle"},
        {"name": "Security Score", "value": "85.5%", "icon": "shield"},
        {"name": "Compliance Score", "value": "92.3%", "icon": "check-square"}
    ]

