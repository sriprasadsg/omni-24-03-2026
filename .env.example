# Environment Configuration for Docker Deployment

# ============================================
# JWT Configuration (Required)
# ============================================
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-this-to-a-secure-random-key
JWT_REFRESH_SECRET_KEY=change-this-to-another-secure-random-key

# ============================================
# Database Configuration
# ============================================
MONGODB_URL=mongodb://mongodb:27017/
DATABASE_NAME=omni_platform

# ============================================
# AI Features (Optional)
# ============================================
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# ============================================
# Agent Configuration (Optional)
# ============================================
# Only needed if running with --profile agent
AGENT_TOKEN=
TENANT_ID=

# ============================================
# Application Configuration
# ============================================
# Backend API URL (for frontend)
VITE_API_BASE=http://localhost:5000/api

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Log Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ============================================
# Production Configuration (Optional)
# ============================================
# Only needed if running with --profile production

# Domain name
DOMAIN=your-domain.com

# SSL Configuration
SSL_CERT_PATH=./nginx/ssl/cert.pem
SSL_KEY_PATH=./nginx/ssl/key.pem

# Email for Let's Encrypt (if using certbot)
LETSENCRYPT_EMAIL=admin@your-domain.com
