export const mockDelay = (ms) => new Promise((resolve) => setTimeout(resolve, ms));
const fetchWithCache = async (key, endpoint, initialData, updateLocalVar) => {
  try {
    const res = await authFetch(`${API_BASE}${endpoint}`);
    if (!res.ok) throw new Error(`API error: ${res.status}`);
    const data = await res.json();
    localStorage.setItem(`omni_cache_${key}`, JSON.stringify(data));
    updateLocalVar(data);
    return data;
  } catch (e) {
    console.warn(`Backend offline or error for ${key}`, e);
    const cached = localStorage.getItem(`omni_cache_${key}`);
    if (cached) {
      const data = JSON.parse(cached);
      updateLocalVar(data);
      return data;
    }
    return initialData;
  }
};
